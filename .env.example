# ── Supabase (required) ─────────────────────────────────────
# Create a project at https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI provider (optional — falls back to realistic mock mode)
# Poe API key from https://poe.com/api_key (OpenAI-compatible)
POE_API_KEY=

# ── Email (optional — falls back to console logging) ────────
RESEND_API_KEY=
EMAIL_FROM=reports@yourdomain.com

# ── Billing: Polar.sh (optional — demo checkout until configured)
# Create products at https://polar.sh → copy the org access token,
# per-plan product IDs and the webhook secret (endpoint: /api/webhooks/polar).
POLAR_ACCESS_TOKEN=polar_oat_zULUACxiJe35OGIvBlx8esKQO8QAUQbTGziaC4YE5Sk
POLAR_PRODUCT_ID_STARTER=930a801c-d5ac-40f2-9f9c-d064641bf794
POLAR_PRODUCT_ID_PRO=e9252880-7bc0-4710-bcf3-af7905e216ab
POLAR_WEBHOOK_SECRET=
# POLAR_SERVER=sandbox            # use Polar's sandbox environment
# POLAR_SUCCESS_URL=              # defaults to $NEXT_PUBLIC_APP_URL/billing?checkout=success
# POLAR_CUSTOMER_PORTAL_URL=      # where "switch to free" sends subscribers

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
