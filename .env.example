# ── Supabase (required) ─────────────────────────────────────
# Create a project at https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI providers (optional — fall back to realistic mock mode) ──
# SCANS: Poe API key from https://poe.com/api_key (OpenAI-compatible) —
# answers the engines. Leave empty to run scans in mock mode.
POE_API_KEY=

# GENERATION (content, assistant, prompt suggestions): z.ai GLM from
# https://z.ai. glm-4.7-flash is the free tier. Override id / base URL below.
GLM_API_KEY=
GLM_MODEL=glm-4.7-flash
# GLM_BASE_URL=https://api.z.ai/api/paas/v4   # mainland: https://open.bigmodel.cn/api/paas/v4

# Self-hosted Playwright scraper (scrapers/). When set, chatgpt/gemini scans
# are answered by the real consumer UIs through this API; other engines still
# use Poe/mock. Answers take minutes — the scraper runs jobs one at a time.
SCRAPER_API_URL=

# ── Email (optional — falls back to console logging) ────────
RESEND_API_KEY=
EMAIL_FROM=reports@yourdomain.com

# ── Billing: Polar.sh (optional — demo checkout until configured)
# Create products at https://polar.sh → copy the org access token,
# per-plan product IDs and the webhook secret (endpoint: /api/webhooks/polar).
POLAR_ACCESS_TOKEN=polar_oat_zULUACxiJe35OGIvBlx8esKQO8QAUQbTGziaC4YE5Sk
POLAR_PRODUCT_ID_STARTER=930a801c-d5ac-40f2-9f9c-d064641bf794
POLAR_PRODUCT_ID_PRO=e9252880-7bc0-4710-bcf3-af7905e216ab
POLAR_WEBHOOK_SECRET=
# POLAR_SERVER=sandbox            # use Polar's sandbox environment
# POLAR_SUCCESS_URL=              # defaults to $NEXT_PUBLIC_APP_URL/billing?checkout=success
# POLAR_CUSTOMER_PORTAL_URL=      # where "switch to free" sends subscribers

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
